# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=dj-media

# App
NEXT_PUBLIC_APP_URL=https://compakt-219831650310.us-central1.run.app

# Couple Email Verification (recommended for production)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
OTP_DEV_MODE=true

# Dev-only: enable legacy password login (do NOT set in production)
NEXT_PUBLIC_ALLOW_LEGACY_LOGIN=true

# Spotify (optional — for playlist import)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google Calendar Sync (optional — for two-way event sync)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://YOUR_DOMAIN/api/gcal/callback

# Google Cloud Storage (optional — for file uploads)
GCS_BUCKET=

# Clerk (optional — enterprise auth, leave empty to use Supabase only)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
